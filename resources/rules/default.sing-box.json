{
    "log": {
        "disabled": false,
        "level": "info",
        "timestamp": true
    },
    "dns": {
        "strategy": "prefer_ipv4",
        "final": "remote",
        "servers": [
            {
                "tag": "remote",
                "address": "https://1.1.1.1/dns-query",
                "address_resolver": "local",
                "detour": "节点选择"
            },
            {
                "tag": "local",
                "address": "https://223.5.5.5/dns-query",
                "detour": "direct"
            },
            {
                "tag": "block",
                "address": "rcode://success"
            }
        ],
        "rules": [
            {
                "outbound": [
                    "any"
                ],
                "server": "local"
            },
            {
                "clash_mode": "global",
                "server": "remote"
            },
            {
                "clash_mode": "direct",
                "server": "local"
            },
            {
                "rule_set": [
                    "geosite-cn",
                    "geoip-cn"
                ],
                "server": "local"
            },
            {
                "rule_set": [
                    "category-ads-all"
                ],
                "server": "block"
            }
        ]
    },
    "experimental": {
        "cache_file": {
            "enabled": true,
            "path": "cache.db",
            "cache_id": "cache_db",
            "store_fakeip": true
        },
        "clash_api": {
            "external_controller": "127.0.0.1:9090",
            "external_ui": "ui",
            "secret": ""
        }
    },
    "inbounds": [
        {
            "type": "tun",
            "tag": "tun-in",
            "auto_route": true,
            "strict_route": true,
            "endpoint_independent_nat": true,
            "sniff": true,
            "sniff_override_destination": true,
            "domain_strategy": "prefer_ipv4",
            "stack": "system",
            "mtu": 9000,
            "address": [
                "172.19.0.1/30",
                "2001:0470:f9da:fdfa::1/64"
            ]
        },
        {
            "type": "mixed",
            "tag": "mixed-in",
            "listen": "127.0.0.1",
            "listen_port": 2334,
            "sniff": true,
            "sniff_override_destination": true,
            "domain_strategy": "prefer_ipv4"
        },
        {
            "type": "socks",
            "tag": "socks-in",
            "listen": "127.0.0.1",
            "listen_port": 2333,
            "sniff": true,
            "sniff_override_destination": true,
            "domain_strategy": "prefer_ipv4"
        }
    ],
    "outbounds": [
        {
            "type": "selector",
            "tag": "节点选择",
            "default": "自动选择",
            "outbounds": [
                "自动选择",
                "手动切换",
                "故障转移",
                "direct",
                "block"
            ]
        },
        {
            "type": "selector",
            "tag": "手动切换",
            "default": "自动选择",
            "outbounds": [
                "自动选择",
                "故障转移",
                "direct",
                "block"
            ]
        },
        {
            "type": "selector",
