        {
            "type": "selector",
            "tag": "苹果服务",
            "default": "direct",
            "outbounds": [
                "direct",
                "节点选择",
                "自动选择"
            ]
        },
        {
            "type": "selector",
            "tag": "AI服务",
            "default": "节点选择",
            "outbounds": [
                "节点选择",
                "自动选择",
                "故障转移"
            ]
        },
        {
            "type": "selector",
            "tag": "广告拦截",
            "default": "block",
            "outbounds": [
                "block",
                "direct"
            ]
        },
        {
            "type": "urltest",
            "tag": "自动选择",
            "url": "http://www.gstatic.com/generate_204",
            "interval": "10m",
            "tolerance": 100,
            "idle_timeout": "30m",
            "interrupt_exist_connections": false,
            "outbounds": []
        },
        {
            "type": "urltest",
            "tag": "故障转移",
            "url": "http://www.gstatic.com/generate_204",
            "interval": "10m",
            "tolerance": 50,
            "idle_timeout": "30m",
            "interrupt_exist_connections": true,
            "outbounds": []
        },
        {
            "type": "direct",
            "tag": "direct"
        },
        {
            "type": "block",
            "tag": "block"
        },
        {
            "type": "dns",
            "tag": "dns-out"
        }
    ],
    "route": {
        "auto_detect_interface": true,
        "final": "节点选择",
        "rules": [
